            Name = "Shadow",
            Parent = ScreenGui,
            BackgroundColor3 = Theme.Shadow,
            BackgroundTransparency = 0.5,
            Position = UDim2.new(0.5, -width/2 + 4, 0.5, -height/2 + 4),
            Size = UDim2.fromOffset(width, height),
        })
        AddCorner(ShadowFrame, 12)

        local MainFrame = Create("Frame", {
            Name = "MainFrame",
            Parent = ScreenGui,
            BackgroundColor3 = Theme.Background,
            Position = UDim2.new(0.5, -width/2, 0.5, -height/2),
            Size = UDim2.fromOffset(width, height),
            ClipsDescendants = true,
        })
        AddCorner(MainFrame, 12)
        AddStroke(MainFrame, Theme.Divider, 1)

        -- ═══════════════════════════════════════
        -- DRAGGING
        -- ═══════════════════════════════════════
        local dragging, dragInput, dragStart, startPos
        
        MainFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or 
               input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = MainFrame.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)
        
        MainFrame.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or 
               input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                local newPos = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
                Tween(MainFrame, {Position = newPos}, 0.08)
                Tween(ShadowFrame, {Position = UDim2.new(
                    newPos.X.Scale, newPos.X.Offset + 4,
                    newPos.Y.Scale, newPos.Y.Offset + 4
                )}, 0.08)
            end
        end)

        -- ═══════════════════════════════════════
        -- SIDEBAR
        -- ═══════════════════════════════════════
