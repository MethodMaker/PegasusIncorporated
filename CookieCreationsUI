        -- ═══════════════════════════════════════
        -- SIDEBAR NAV BUTTON FACTORY
        -- ═══════════════════════════════════════
        local function CreateSidebarButton(name, order, isFirst)
            local btn = Create("TextButton", {
                Name = "Nav_" .. name,
                Parent = NavContainer,
                BackgroundColor3 = isFirst and Theme.ControlBg or Theme.SidebarBg,
