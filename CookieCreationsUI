--[[
    CookieCreations UI - Dark Purple Themed UI Library for Roblox
    Custom CookieCreations interface design
    
    API (drop-in replacement for SyndicateUI):
        local UILibrary = loadstring(...)()
        local MainUI = UILibrary.new(AccentColor)
        local Window = MainUI:LoadWindow(Title, Size)
        local Page = Window.NewPage(Name)
        local Section = Page.NewSection(Name)
        Section.Toggle(Name, Default, Callback)
        Section.Slider(Name, Options, Callback)
        Section.Dropdown(Name, Options, Callback)
        Section.ColorPicker(Name, Default, Callback)
        Window.SetPosition(UDim2)
        Window.GetPosition()
--]]

local CookieUI = {}

