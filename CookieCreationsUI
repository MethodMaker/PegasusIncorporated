                TextSize = 13,
                Font = isFirst and FontSemibold or Font,
                TextXAlignment = Enum.TextXAlignment.Left,
            })

            -- Hover effect
            btn.MouseEnter:Connect(function()
                if btn ~= SidebarButtons[ActivePage] then
                    Tween(btn, {BackgroundTransparency = 0.3, BackgroundColor3 = Theme.ControlBg}, 0.15)
                end
            end)
            btn.MouseLeave:Connect(function()
                if btn ~= SidebarButtons[ActivePage] then
                    Tween(btn, {BackgroundTransparency = 1}, 0.15)
                end
            end)

            return btn, indicator, label
        end

        -- ═══════════════════════════════════════
        -- TAB BUTTON FACTORY
        -- ═══════════════════════════════════════
